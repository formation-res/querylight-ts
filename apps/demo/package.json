{
  "name": "@querylight/demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:site": "tsx build/generate-site.ts",
    "build:client": "tsx build/build-client.ts",
    "dev": "npm run generate:site && npm run build:client && hugo server --source . --disableFastRender --port 4173",
    "build": "npm run generate:site && npm run build:client && hugo --source . --gc --minify",
    "check": "npm run generate:site && npm run build:client && hugo --source . --gc --minify --panicOnWarning",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@tryformation/querylight-ts": "0.9.0",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.25.10",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "tsx": "^4.20.6"
  }
}
