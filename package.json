{
  "name": "querylight-ts-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace @tryformation/querylight-ts",
    "dev": "npm run dev --workspace @querylight/demo",
    "check:demo": "npm run check --workspace @querylight/demo",
    "profile:demo": "node scripts/profile-demo.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
